# ─── Ollama (Local LLM — No API Key Needed) ───────────────────────────────
OLLAMA_MODEL=llama3
OLLAMA_BASE_URL=http://localhost:11434

# ─── Local Embeddings (sentence-transformers — No API Key Needed) ──────────
EMBEDDING_MODEL=all-MiniLM-L6-v2

# ─── Telegram Alerts ──────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
TELEGRAM_CHAT_ID=your_telegram_chat_id_here

# ─── Sentry Mode ──────────────────────────────────────────────────────────
# Options: epi | eco | supply | general
SENTRY_MODE=general

# ─── Alert Threshold ──────────────────────────────────────────────────────
# Minimum relevance score (0.0–1.0) required to trigger full analysis
ALERT_THRESHOLD=0.4

# ─── RSS Feeds ────────────────────────────────────────────────────────────
# Epi-Sentry feeds (disease & health)
EPI_FEEDS=https://www.who.int/rss-feeds/news-english.xml

# Eco-Sentry feeds (climate & disasters)
ECO_FEEDS=https://www.nhc.noaa.gov/nhc_at.xml

# Supply-Sentry feeds (supply chain & ESG)
SUPPLY_FEEDS=https://feeds.reuters.com/reuters/businessNews

# General feeds (fallback)
RSS_FEEDS=https://feeds.bbci.co.uk/news/world/rss.xml

# Poll interval in seconds (default: 5 minutes)
POLL_INTERVAL=300

# ─── User Profile ─────────────────────────────────────────────────────────
USER_PROFILE_PATH=user_profile.json
